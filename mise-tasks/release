#!/usr/bin/env bash
#MISE description="打包插件为 zip，用于 GitHub Release"
set -euo pipefail

VERSION="${1:-1.0.0}"
ZIP_NAME="moonbit-${VERSION}.zip"

echo "打包插件为 ${ZIP_NAME} ..."

git archive --format=zip --output="${ZIP_NAME}" "v${VERSION}" \
  --add-file=manifest.json

echo "✓ 已生成 ${ZIP_NAME}"
echo ""
echo "上传到 GitHub Release 后，还需在 vfox-plugins 提交 PR："
echo "  https://github.com/version-fox/vfox-plugins"
echo ""
echo "sources/moonbit.json 内容："
echo '{
  "name": "moonbit",
  "manifestUrl": "https://github.com/morning-start/moonbit/releases/download/v'${VERSION}'/manifest.json",
  "test": {
    "version": "latest",
    "check": "moon version",
    "resultRegx": "moon .+"
  }
}'
